        ]
      ]
    },
    "企微通知": {
      "main": [[ { "node": "返回响应", "type": "main", "index": 0 } ]]
    },
    "飞书通知": {
      "main": [[ { "node": "返回响应", "type": "main", "index": 0 } ]]
    }
  },
  "settings": {
    "callerPolicy": "workflowsFromSameOwner"
  },
  "versionId": "1.0.0",
