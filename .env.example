# 数据库连接
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chatbot"

# Dify 配置
DIFY_API_URL="https://api.dify.ai/v1/chat-messages"
DIFY_API_KEY="app-xxxxxxxxxxxxx"

# 企微机器人 webhook（直接通知，无需 n8n）
WECOM_WEBHOOK_URL="https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY"

# n8n webhook（可选，部署 n8n 后使用）
N8N_WEBHOOK_URL="https://your-n8n.com/webhook/lead-notify"

# n8n 管理账号（docker-compose 中使用）
N8N_USER=admin
N8N_PASSWORD=admin

# 服务端口
PORT=3001
# Comma-separated HTTPS webhook host allowlist
WEBHOOK_ALLOWED_HOSTS=

# Redis 用于跨实例限流和 SSE 连接租约
REDIS_URL="redis://localhost:6379"
